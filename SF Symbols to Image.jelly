import Shortcuts
#Color: green, #Icon: photoStack

/*
Converts SF Symbols to image. Requires the free Actions app
2024-07-20 	v1.2
https://routinehub.co/user/gluebyte
https://mastodon.social/@gluebyte
*/
randomNumber(min: 1, max: 2) >> randomNumber
if(Random Number == 1) {
	getIP() >> getIP
	if(Current IP Address != nil) {
		downloadURL(url: "https://update.gluebyte.workers.dev/?id=92065B84") >> downloadURL
		if(Contents of URL .contains "2024-07-20") { >> IFResult
			menu(, [🌏  Go to RoutineHub, 👾  Download Update, ⮐  Not Now]) {
			case("🌏  Go to RoutineHub"): >> MenuResult
				openURL(url: "https://routinehub.co/shortcut/19080/") >> openURL
				exit()
			case("👾  Download Update"): >> MenuResult 1
				downloadURL(url: "https://routinehub.co/api/v1/shortcuts/19080/versions/latest") >> downloadURL 1
				matchText(text: "${Contents of URL}", regex: "(?<="id":\D?)\d+") >> matchText
				expandURL(url: "https://routinehub.co/download/${Matches}/") >> expandURL
				replaceText(input: "${Expanded URL}", find: "^.+icloud.com/", replace: "shortcuts://", isRegex: true) >> replaceText
				openURL(url: Updated Text) >> openURL 1
				exit()
			case("⮐  Not Now"):
			} >> MenuResult 2
		} >> IFResult 1
	} >> IFResult 2
} >> IFResult 3
/*
Please install the Actions app

https://apps.apple.com/app/id1586435171
*/
//Unable to get shortcuts action com.sindresorhus.Actions.GetEmojisIntent
list(items: (
    "{\"property\":{\"Symbol\":\"cloud.sun.rain.fill\",\"Symbol Color\":\"74a7fe\",\"Background Color\":\"transparent\",\"Rendering\":\"multicolor (iOS & visionOS.only)\",\"Weight\":\"Regular\",\"Size\":\"Small (vCard)\"}, \"menu\":{\"Weight\":[\"Ultra Light\",\"Thin\",\"Light\",\"Regular\",\"Medium\",\"Semibold\",\"Bold\",\"Heavy\",\"Black\"], \"Size\":[\"Small (vCard)\",\"Medium\",\"Large\"], \"pixel\":{\"Small (vCard)\":{\"1\":37,\"2\":92,\"3\":93},\"Medium\":{\"1\":128,\"2\":309,\"3\":315},\"Large\":{\"1\":340,\"2\":826,\"3\":840}}}, }"
)) >> list
getDictionaryFrom(input: List) >> getDictionaryFrom
