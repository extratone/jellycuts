                                                    WFSerializationType = WFTextTokenString;
                                                };
                                                WFValue =                                                 {
                                                    Value =                                                     {
                                                        string = "\n\U26d4\Ufe0f No media has been downloaded\n\nPlease choose \U2018Retry\U2019 and share to \U2018Instagram Download\U2019 again. If problem persists, try toggling WiFi. If you cannot download stories/highlights, try using Safe Mode only for posts/reels.\n\n\Ud83d\Udeb8 To download stories (of private accounts) without share button:\n\n\U278a  Share account\U2019s post/reel to \U2018Instagram Download\U2019\n\U278b  Navigate to stories\n\U278c  Reload webpage\n\U278d  Tap Safari\U2019s share button to run \U2018Instagram Download\U2019\n";
